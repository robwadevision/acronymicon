{
  "manifest_version": 3,
  "name": "Acronymicon",
  "version": "1.5.0",
  "description": "Detects acronyms on web pages and shows instant definitions via tooltip. Great for job ads, technical docs, and more.",
  "author": "Rob Wade",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Acronymicon"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/constants.js", "src/analytics.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/acronyms.*.json"],
      "matches": ["<all_urls>"]
    }
  ],

  "host_permissions": ["https://www.google-analytics.com/*"],

  "permissions": ["storage", "activeTab"],

  "background": {
    "service_worker": "src/background.js"
  }
}
